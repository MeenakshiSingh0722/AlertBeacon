# AlertBeacon Backend Environment Configuration

# Database Configuration
DATABASE_URL=postgresql+asyncpg://alertbeacon:password@localhost:5432/alertbeacon_db
# For development with SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./alertbeacon.db

# Redis Configuration (for WebSocket support)
REDIS_URL=redis://localhost:6379/0

# AI Configuration
# Anthropic Claude API Key (optional - will use mock AI if not provided)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-sonnet-20240229

# OpenAI API Key (alternative to Anthropic)
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
PROJECT_NAME=AlertBeacon
DEBUG=true
DEMO_MODE=true
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Logging Configuration
LOG_LEVEL=INFO

# WebSocket Configuration
WEBSOCKET_ENABLED=true

# Optional: External API Keys
# NEWS_API_KEY=your_news_api_key
# WEATHER_API_KEY=your_weather_api_key
